{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SynapseSnip",
  "version": "0.1.1",
  "identifier": "com.synapsesnip.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SynapseSnip",
        "width": 520,
        "height": 420,
        "minWidth": 400,
        "minHeight": 350,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' snip: pending: data: blob: http://snip.localhost http://pending.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; media-src 'self' data: blob: file:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/ffmpeg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
